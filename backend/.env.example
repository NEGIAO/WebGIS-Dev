# WebGIS Backend 环境变量配置示例
# 复制此文件为 .env 并填入实际的值

# Supabase 配置
# 从 Supabase 项目设置 > API 中获取
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key

# 认证与持久化存储配置
# HF Space 建议使用 /data 持久化卷
AUTH_DB_PATH=/data/webgis_auth.db
AUTH_SESSION_EXPIRE_HOURS=72

# 邮件服务配置（Resend HTTP API，不依赖 SMTP 端口）
# 注册 https://resend.com 获取 API Key（免费 100封/天）
# RESEND_API_KEY 必须在 HF Space Secrets 中配置
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# FastAPI 应用配置（可选）
# APP_ENV=development
# LOG_LEVEL=INFO
