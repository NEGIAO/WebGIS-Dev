# WebGIS Backend 环境变量配置示例
# 复制此文件为 .env 并填入实际的值

# Supabase 配置
# 从 Supabase 项目设置 > API 中获取
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key

# 认证与持久化存储配置
# HF Space 建议使用 /data 持久化卷
AUTH_DB_PATH=/data/webgis_auth.db
AUTH_SESSION_EXPIRE_HOURS=72

# 邮件服务配置（QQ邮箱 SMTP）
# SMTP_USER 和 SMTP_PASSWORD 必须在 HF Space Secrets 中配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
# SMTP_USER=your_email@qq.com       # HF Secret
# SMTP_PASSWORD=your_auth_code       # HF Secret
SMTP_USE_SSL=true

# FastAPI 应用配置（可选）
# APP_ENV=development
# LOG_LEVEL=INFO
