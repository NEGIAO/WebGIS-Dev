# WebGIS 环境变量配置示例
# 复制此文件为 .env 或 .env.local 并填入您的实际值

# ========== 地图服务配置 ==========
# 天地图 Token (必需)
# 申请地址：https://console.tianditu.gov.cn/
VITE_TIANDITU_TK=your_tianditu_token_here

# ========== AI 助手配置 ==========
# LLM API 端点 (可选，默认使用 SiliconFlow)
VITE_LLM_ENDPOINT=https://api.siliconflow.cn/v1/chat/completions

# LLM API Key (推荐配置)
# SiliconFlow 申请：https://cloud.siliconflow.cn/
VITE_LLM_API_KEY=your_api_key_here

# LLM 模型名称 (可选)
VITE_LLM_MODEL=deepseek-ai/DeepSeek-V2.5
