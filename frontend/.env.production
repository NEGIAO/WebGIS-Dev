# WebGIS 前端生产环境配置
# 此文件在 npm run build 时使用
# 用于正式部署到 GitHub Pages + Hugging Face Spaces

# ========== 后端 API 配置 ==========
# 生产环境: 使用 Hugging Face Spaces 后端
VITE_BACKEND_URL=https://negiao-webgis.hf.space

# ========== 地图服务配置 ==========
# 天地图 Token
# VITE_TIANDITU_TK=your_tianditu_token_here

# 高德 Web 服务 Key
# VITE_AMAP_WEB_SERVICE_KEY=your_amap_key_here

# ========== AI 助手配置 ==========
# LLM API 端点
# VITE_LLM_ENDPOINT=https://api.siliconflow.cn/v1/chat/completions

# LLM API Key
# VITE_LLM_API_KEY=your_api_key_here
