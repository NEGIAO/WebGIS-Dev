# WebGIS 环境变量配置示例
# 复制此文件为 .env 或 .env.local 并填入您的实际值

# ========== 部署环境配置 ==========
# VITE_BASE_URL 用于多种部署环境支持
# 本地开发（默认）: './'
# GitHub Pages (WebGIS-Dev 仓库): '/WebGIS-Dev/'
# GitHub Pages (WebGIS/io 仓库): '/WebGIS/'
# Posit Connect Cloud: '/WebGIS/'
# 用法: VITE_BASE_URL=/WebGIS-Dev/ npm run build
VITE_BASE_URL=./

// VITE_BACKEND_URL 用于指定后端 API 的基础 URL
// 本地开发: http://localhost:7860
VITE_BACKEND_URL=your_backend_url_here

// VITE_TILE_PROXY_BASE_URL 用于指定瓦片代理根地址，默认复用 VITE_BACKEND_URL
// 线上代理: https://negiao-webgis.hf.space
// 自动拼接格式: {VITE_TILE_PROXY_BASE_URL}/proxy/{原始瓦片URL}
VITE_TILE_PROXY_BASE_URL=https://negiao-webgis.hf.space
// VITE_TILE_PROXY_MODE=fallback 直连失败后再走代理；always 强制代理；off 关闭代理
VITE_TILE_PROXY_MODE=fallback

# ========== 地图服务配置 ==========
# 天地图 TK 与 Cesium Ion Token 推荐通过管理员后台配置到后端数据库。
# 前端运行时会从 /api/runtime-config/map-tokens 获取一次，然后直连第三方服务。
# 不要在 VITE_* 环境变量中写入天地图/Cesium 真实 token，Vite 会把它们打进前端产物。

# 高德 Web 服务 Key (推荐，用于地名搜索/地理编码/IP定位)
# 申请地址：https://lbs.amap.com/
# Amap key is configured in the admin API key panel, not in frontend env.

# ========== AI 助手配置 ==========
# LLM API 端点 (可选，默认使用 SiliconFlow)
# Agent/LLM endpoint is configured in the admin Agent panel.

# LLM API Key (推荐配置)
# SiliconFlow 申请：https://cloud.siliconflow.cn/
# Agent/LLM API key is configured in the admin API key panel.

# LLM 模型名称 (可选)
# Agent/LLM model is configured in the admin Agent panel.
